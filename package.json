{
  "name": "timelog-app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint ../"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "globals": "^17.3.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/scripts/**/*.js",
      "!src/scripts/sw.js",
      "!src/scripts/timerDOM.js",
      "!src/scripts/script.js",
      "!src/scripts/navigation.js",
      "!src/scripts/training.js",
      "!src/scripts/settingsDOM.js",
      "!src/scripts/barchartDOM.js",
      "!src/scripts/localStorage.js",
      "!src/scripts/overviewDOM.js",
      "!src/scripts/statsDisplayDOM.js",
      "!src/scripts/swCall.js",
      "!src/scripts/addTimeDOM.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "statements": 80,
        "functions": 80,
        "branches": 80
      }
    }
  }
}
